#!/usr/bin/env bash
# ruby-on-rails/bin/update

source "$(dirname "$0")/_lib.sh"

banner

# TODO: This is inheritly dangerous, we should probably 
# only allow updating specific gems, or at least 
# require a confirmation prompt, or detect if --all was passed.
if [ "$#" -eq 0 ]; then
  bundle update --all
else
  bundle update "$@"
fi
