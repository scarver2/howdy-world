#!/usr/bin/env bash
# odin-http/bin/lint

source "$(dirname "$0")/_lib.sh"



require_command odin

info "Checking formatting..."

if ! odin_with_deps check .; then
  error "Formatting issues detected. Run: odin fmt ."
  exit 1
fi

success "Formatting clean"

info "Validating compile..."

# Compile using same flags as build, but discard output
odin_with_deps build main.odin -file \
  -out:/dev/null

success "Lint passed"
