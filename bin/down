#!/usr/bin/env bash
# bin/down

# Default behavior: down --remove-orphans
# You can override/extend by passing args, e.g.:
#   bin/down --volumes
#   bin/down --remove-orphans --volumes

source "$(dirname "$0")/_lib.sh"
cd "$ROOT_DIR"

banner

if [[ $# -eq 0 ]]; then
  compose down --remove-orphans
else
  compose down "$@"
fi
