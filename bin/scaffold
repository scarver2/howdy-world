#!/usr/bin/env bash
# bin/scaffold

set -euo pipefail
source "$(dirname "$0")/_lib.sh"
cd "$ROOT_DIR"

usage() {
  cat <<'USAGE'
Usage:
  bin/scaffold <endpoint-name> [port]

If port is omitted, defaults to 3000.
USAGE
  exit 1
}

ENDPOINT="${1:-}"
PORT="${2:-3000}"

[[ -z "$ENDPOINT" ]] && usage

if ! [[ "$ENDPOINT" =~ ^[a-z][a-z0-9-]*$ ]]; then
  abort "Invalid endpoint name '$ENDPOINT'. Must be lowercase kebab-case starting with a letter."
fi

banner "Scaffold Endpoint"

ensure_root_context
ensure_clean_working_tree
ensure_master_up_to_date

# -------------------------------------------------------------------
# Branch handling (non-single-use)
# -------------------------------------------------------------------

git_branch_exists() {
  git show-ref --verify --quiet "refs/heads/$1"
}

prepare_endpoint_branch() {
  local current_branch
  current_branch="$(git_current_branch)"

  if ! git_branch_exists "$ENDPOINT"; then
    if [[ "$current_branch" != "master" ]]; then
      echo
      echo "Endpoint branch '$ENDPOINT' does not exist."
      echo "You must be on 'master' to create it."
      echo "Current branch: $current_branch"
      echo
      exit 1
    fi

    git checkout -b "$ENDPOINT"
    echo "Created and switched to branch '$ENDPOINT'"
  else
    echo "Branch '$ENDPOINT' already exists."
    echo "Scaffolding on current branch: $current_branch"
  fi
}

prepare_endpoint_branch

TEMPLATE_DIR="$ROOT_DIR/bin/templates/generic"

if [[ ! -d "$TEMPLATE_DIR" ]]; then
  abort "Template directory not found: $TEMPLATE_DIR"
fi

echo
echo "Scaffolding endpoint: $ENDPOINT"
echo

OVERWRITE_ALL=0

# -------------------------------------------------------------------
# Render template to temp (Option 1)
# -------------------------------------------------------------------

render_template_to_tmp() {
  local src="$1"
  local endpoint="$2"
  local port="$3"

  local tmp
  tmp="$(mktemp)"

  cp "$src" "$tmp"

  sed -i '' \
    -e "s/__ENDPOINT__/$endpoint/g" \
    -e "s/__PORT__/$port/g" \
    "$tmp" 2>/dev/null || \
  sed -i \
    -e "s/__ENDPOINT__/$endpoint/g" \
    -e "s/__PORT__/$port/g" \
    "$tmp"

  echo "$tmp"
}

# -------------------------------------------------------------------
# Prompt logic
# -------------------------------------------------------------------

prompt_overwrite() {
  local target="$1"
  local rendered="$2"

  if (( OVERWRITE_ALL == 1 )); then
    return 0
  fi

  while true; do
    echo "File exists: $target"
    read -rp "Overwrite? [Yes]  [No]  [Diff]  [All]  [Quit]: " choice < /dev/tty

    case "${choice,,}" in
      y|yes)
        return 0
        ;;
      n|no|"")
        return 1
        ;;
      d|diff)
        diff -u "$target" "$rendered" || true
        ;;
      a|all)
        OVERWRITE_ALL=1
        return 0
        ;;
      q|quit)
        exit 1
        ;;
      *)
        echo "Invalid option."
        ;;
    esac
  done
}

# -------------------------------------------------------------------
# Copy logic (Option 4 auto-skip if identical)
# -------------------------------------------------------------------

copy_file() {
  local src="$1"
  local dest="$2"

  local rendered
  rendered="$(render_template_to_tmp "$src" "$ENDPOINT" "$PORT")"

  if [[ -f "$dest" ]]; then
    if cmp -s "$dest" "$rendered"; then
      rm -f "$rendered"
      return
    fi

    if prompt_overwrite "$dest" "$rendered"; then
      cp "$rendered" "$dest"
    fi
  else
    mkdir -p "$(dirname "$dest")"
    cp "$rendered" "$dest"
  fi

  rm -f "$rendered"
}

# -------------------------------------------------------------------
# Copy templates
# -------------------------------------------------------------------

while IFS= read -r -d '' file; do
  rel="${file#$TEMPLATE_DIR/}"
  target="$ENDPOINT/$rel"
  copy_file "$file" "$target"
done < <(find "$TEMPLATE_DIR" -type f -print0)

# Ensure bin scripts executable
if [[ -d "$ENDPOINT/bin" ]]; then
  chmod +x "$ENDPOINT/bin/"* 2>/dev/null || true
fi

# -------------------------------------------------------------------
# Compose injection (template-driven)
# -------------------------------------------------------------------

COMPOSE_TEMPLATE="$ROOT_DIR/bin/templates/compose_service.yml"

if [[ -f "$COMPOSE_TEMPLATE" ]]; then
  tmp="$(mktemp)"
  cp "$COMPOSE_TEMPLATE" "$tmp"

  sed -i '' \
    -e "s/__ENDPOINT__/$ENDPOINT/g" \
    -e "s/__PORT__/$PORT/g" \
    "$tmp" 2>/dev/null || \
  sed -i \
    -e "s/__ENDPOINT__/$ENDPOINT/g" \
    -e "s/__PORT__/$PORT/g" \
    "$tmp"

  if ! compose_service_exists "$ENDPOINT"; then
    yaml_merge_block ".services" "$tmp" compose.yml
    compose_sort_services
  fi

  rm "$tmp"
fi

# -------------------------------------------------------------------
# NGINX injection (template-driven)
# -------------------------------------------------------------------

NGINX_TEMPLATE="$ROOT_DIR/bin/templates/nginx_endpoint.conf"
NGINX_TARGET="$ROOT_DIR/_infrastructure/proxy/nginx/conf.d/$ENDPOINT.conf"

if [[ -f "$NGINX_TEMPLATE" ]]; then
  tmp="$(mktemp)"
  cp "$NGINX_TEMPLATE" "$tmp"

  sed -i '' \
    -e "s/__ENDPOINT__/$ENDPOINT/g" \
    -e "s/__PORT__/$PORT/g" \
    "$tmp" 2>/dev/null || \
  sed -i \
    -e "s/__ENDPOINT__/$ENDPOINT/g" \
    -e "s/__PORT__/$PORT/g" \
    "$tmp"

  if [[ -f "$NGINX_TARGET" ]]; then
    if ! cmp -s "$NGINX_TARGET" "$tmp"; then
      if prompt_overwrite "$NGINX_TARGET" "$tmp"; then
        cp "$tmp" "$NGINX_TARGET"
      fi
    fi
  else
    cp "$tmp" "$NGINX_TARGET"
  fi

  rm "$tmp"
fi

echo
echo "Scaffold complete. Review changes:"
echo
git status --short
echo

# -------------------------------------------------------------------
# Commit prompt
# -------------------------------------------------------------------

if confirm "Create git commit for this endpoint?"; then
  git add -A
  git commit -m "Add $ENDPOINT endpoint"
  echo "✔ Commit created."
else
  echo "Skipping commit. Changes remain unstaged."
fi

echo
echo "✔ Endpoint '$ENDPOINT' scaffolded successfully."