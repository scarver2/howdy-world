#!/usr/bin/env bash
# zig/bin/test

source "$(dirname "$0")/_lib.sh"

banner

require_command zig
require_command curl

echo "Running unit tests..."
zig test howdy.zig

echo "Running request test..."
RESPONSE="$(curl -sf http://localhost:3000)" || abort "Server not responding at http://localhost:3000"
echo "$RESPONSE" | grep -q "Howdy, World!" || abort "Response missing 'Howdy, World!'"
echo "✅ Request test passed"
